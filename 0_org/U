FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0 0 0);
boundaryField
{
    inletWater
    {
        // Same log-law inlet as the scour case (0_org/U.b), but WITHOUT the
        // start-up ramp: the interior is initialised with the same profile
        // by setExprFields, so ramping the inlet from zero would only send
        // a deceleration wave through the domain.
        type            codedFixedValue;
        value           uniform (0 0 0);
        name            logLawInlet;
        code
        #{
            const scalar ustar = 0.01617;
            const scalar kappa = 0.41;
            const scalar ks    = 1.5e-3;   // 2.5*d50
            vectorField& U = *this;
            const vectorField& Cf = patch().Cf();
            forAll(U, i)
            {
                scalar z = max(Cf[i].z(), ks/30.0);   // z = 0 is the bed
                U[i] = vector((ustar/kappa)*log(30.0*z/ks), 0, 0);
            }
        #};
    }
    // Zero-face leftovers of the full mesh (all their faces are in z < 0
    // and were removed together with the bed cells by subsetMesh).
    "(inletSediment|outletSediment|bottom)"
    {
        type            noSlip;
    }
    outletWater
    {
        type            inletOutlet;
        inletValue      uniform (0 0 0);
        value           uniform (0 0 0);
    }
    "(sideWalls|pier|bed)"
    {
        type            noSlip;
    }
    top
    {
        type            slip;
    }
}
