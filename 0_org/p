FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Kinematic pressure (pimpleFoam, incompressible). Not mapped to the scour
// case: sedFoam recomputes p_rbgh from the mapped velocity field in the
// first PISO sweep.
dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    "(inletWater|inletSediment)"
    {
        type            zeroGradient;
    }
    "(outletWater|outletSediment)"
    {
        type            fixedValue;
        value           uniform 0;
    }
    "(sideWalls|bottom|pier|bed|top)"
    {
        type            zeroGradient;
    }
}
