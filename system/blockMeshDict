FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Rigid approach section: the erodible bed now starts at x = -0.6 instead of
// the inlet (x = -0.8). For -0.8 < x < -0.6 the floor is a rigid wall at
// z = 0, flush with the initial bed surface (false floor, as in a flume).
// This removes the leading-edge erosion/over-compaction artifact at the
// sediment inlet. The rigid floor faces belong to the 'bottom' wall patch,
// so no 0_org boundary condition changes are needed.

convertToMeters 1;

vertices
(
    // z = -0.06 (only under the erodible bed, x >= -0.6)
    (-0.6 -0.125 -0.06)  // 0
    ( 0.6 -0.125 -0.06)  // 1
    ( 0.6  0.125 -0.06)  // 2
    (-0.6  0.125 -0.06)  // 3

    // z = 0.00 (rigid floor upstream / initial bed surface downstream)
    (-0.8 -0.125  0.00)  // 4
    (-0.6 -0.125  0.00)  // 5
    ( 0.6 -0.125  0.00)  // 6
    ( 0.6  0.125  0.00)  // 7
    (-0.6  0.125  0.00)  // 8
    (-0.8  0.125  0.00)  // 9

    // z = 0.05
    (-0.8 -0.125  0.05)  // 10
    (-0.6 -0.125  0.05)  // 11
    ( 0.6 -0.125  0.05)  // 12
    ( 0.6  0.125  0.05)  // 13
    (-0.6  0.125  0.05)  // 14
    (-0.8  0.125  0.05)  // 15
);

blocks
(
    // Erodible bed, x in [-0.6, 0.6] (dx = 0.01 m as before)
    hex (0 1 2 3 5 6 7 8)
    (120 25 12)
    simpleGrading (1 1 0.2)

    // Water column over the rigid approach, x in [-0.8, -0.6]
    hex (4 5 8 9 10 11 14 15)
    (20 25 12)
    simpleGrading (1 1 5)

    // Water column over the erodible bed
    hex (5 6 7 8 11 12 13 14)
    (120 25 12)
    simpleGrading (1 1 5)
);

boundary
(
    // Buried upstream end of the sand pit (vertical face at x = -0.6, z < 0)
    inletSediment
    {
        type patch;
        faces
        (
            (0 5 8 3)
        );
    }

    inletWater
    {
        type patch;
        faces
        (
            (4 10 15 9)
        );
    }

    outletSediment
    {
        type patch;
        faces
        (
            (1 2 7 6)
        );
    }

    outletWater
    {
        type patch;
        faces
        (
            (6 7 13 12)
        );
    }

    sideWalls
    {
        type wall;
        faces
        (
            // y = -0.125
            (0 1 6 5)
            (4 5 11 10)
            (5 6 12 11)

            // y = 0.125
            (3 8 7 2)
            (9 15 14 8)
            (8 14 13 7)
        );
    }

    bottom
    {
        type wall;
        faces
        (
            (0 3 2 1)   // z = -0.06 under the erodible bed
            (4 9 8 5)   // z =  0.00 rigid approach floor
        );
    }

    top
    {
        type wall;
        faces
        (
            (10 11 14 15)
            (11 12 13 14)
        );
    }
);

mergePatchPairs
(
);
