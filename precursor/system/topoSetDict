FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Water column of the scour mesh: everything above the initial bed surface
// (z = 0). z = 0 is a blockMesh block boundary, so no cell straddles it and
// the subsetMesh cut is exact. The exposed z = 0 faces become the rigid
// 'bed' wall patch (subsetMesh waterCells -patch bed).
actions
(
    {
        name    waterCells;
        type    cellSet;
        action  new;
        source  boxToCell;
        box     (-10 -10 0) (10 10 10);
    }
);
