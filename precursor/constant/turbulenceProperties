FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
simulationType      RAS;
RAS
{
    // Single-phase k-omega: the closest standard model to the scour case's
    // twophasekOmega (both Wilcox k-omega variants), so the mapped k/omega
    // fields are a consistent initial condition for sedFoam.
    RASModel        kOmega;
    turbulence      on;
    printCoeffs     on;
}
