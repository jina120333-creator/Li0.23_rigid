FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Equilibrium log-layer estimate: k = ustar^2/sqrt(Cmu) = 0.016^2/0.3
// ~ 8.5e-4 m2/s2 (same value as the scour case 0_org/k.b).
dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 8.5e-4;

boundaryField
{
    "(inletWater|inletSediment)"
    {
        type            fixedValue;
        value           $internalField;
    }
    "(outletWater|outletSediment)"
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    top
    {
        //type            zeroGradient;
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    "(sideWalls|bottom|pier|bed)"
    {
        type            kqRWallFunction;
        value           $internalField;
    }
}
